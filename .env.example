# -----------------------------------------------------------------------
# Copy this file to .env for local development (Python runs on your host)
# Copy to .env.docker for fully-containerized runs (update URLs below)
# -----------------------------------------------------------------------

# --- Ollama ---
# Ollama runs natively on your host so it can use the GPU.
# Local dev: use localhost. Fully-containerized: use host.docker.internal
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b

# --- OpenSearch ---
# Local dev (Python on host, OpenSearch in Docker): localhost:9200
# Fully-containerized (Python in Docker): opensearch:9200
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=image_evaluations

# --- Paths ---
INPUT_IMAGES_DIR=./input_images
LOG_DIR=./logs
